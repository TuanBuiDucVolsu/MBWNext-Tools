{
  "manifest_version": 3,
  "name": "MBWNext Extensions",
  "version": "1.3.0",
  "description": "Công cụ MBWNext (Frappe/ERPNext): Dev debug, triển khai, và hỗ trợ người dùng cuối (tìm field, attachments, lịch sử…).",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.mbwnext.com/*",
        "http://*.mbwnext.com/*",
        "http://localhost/*",
        "http://localhost:*/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["src/common.js", "src/nguoi-dung-tools.js", "src/dev-tools.js", "src/trien-khai-tools.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ]
}
